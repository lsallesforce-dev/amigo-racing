{
    "functions": {
        "api/index.ts": {
            "includeFiles": "api/_server/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.ts"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/index.ts"
        },
        {
            "source": "/robots.txt",
            "destination": "/api/index.ts"
        },
        {
            "source": "/events/:id(\\d+)",
            "has": [{ "type": "header", "key": "user-agent", "value": ".*(WhatsApp|Facebot|facebookexternalhit|Twitterbot|Slackbot|LinkedInBot|TelegramBot|Discordbot).*" }],
            "destination": "/api/index.ts"
        },
        {
            "source": "/championship/:id(\\d+)",
            "has": [{ "type": "header", "key": "user-agent", "value": ".*(WhatsApp|Facebot|facebookexternalhit|Twitterbot|Slackbot|LinkedInBot|TelegramBot|Discordbot).*" }],
            "destination": "/api/index.ts"
        },
        {
            "source": "/((?!api/|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}