{
    "functions": {
        "api/index.ts": {
            "includeFiles": "api/_server/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.ts"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/index.ts"
        },
        {
            "source": "/robots.txt",
            "destination": "/api/index.ts"
        },
        {
            "source": "/events/:id(\\d+)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/championship/:id(\\d+)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/((?!api/|assets/|favicon|.*\\.(?:css|js|png|jpg|svg|ico|json)).*)",
            "destination": "/index.html"
        }
    ]
}